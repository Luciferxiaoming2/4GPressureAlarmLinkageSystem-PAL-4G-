APP_NAME=PAL_4G Backend
APP_VERSION=0.1.0
API_V1_PREFIX=/api/v1
DATABASE_URL=sqlite+aiosqlite:///./pal_4g.db
SECRET_KEY=replace-with-a-secure-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ALGORITHM=HS256
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123456
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
USR_CLOUD_ENABLED=false
USR_CLOUD_API_BASE_URL=https://cloudapi.usr.cn
USR_CLOUD_APP_KEY=
USR_CLOUD_APP_SECRET=
USR_CLOUD_ACCOUNT=
USR_CLOUD_PASSWORD=
USR_CLOUD_TOKEN_EXPIRE_SECONDS=7200
USR_CLOUD_DEVICE_LIST_PATH=/usrCloud/device/list
USR_CLOUD_DEVICE_DETAIL_PATH=/usrCloud/device/info
USR_CLOUD_PROJECT_ID=
USR_CLOUD_DEVICE_ID=
USR_CLOUD_DEVICE_NO=
USR_CLOUD_CUSDEVICE_NO=
USR_CLOUD_GATEWAY_ID=
USR_CLOUD_GATEWAY_CLIENT_ID=
USR_CLOUD_GATEWAY_PASSWORD=
USR_CLOUD_GATEWAY_MQTT_HOST=
USR_CLOUD_GATEWAY_MQTT_PORT=1883
USR_CLOUD_HTTP_PUSH_ENABLED=false
USR_CLOUD_HTTP_PUSH_CALLBACK_URL=
USR_CLOUD_HTTP_PUSH_VERIFY_TOKEN=
LOG_LEVEL=INFO
ALARM_NOTIFICATION_DISPATCH_INTERVAL_SECONDS=60
WECHAT_ENABLED=false
WECHAT_LOGIN_USE_REAL_CODE2SESSION=false
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_API_BASE_URL=https://api.weixin.qq.com
WECHAT_SUBSCRIBE_TEMPLATE_ID=
WECHAT_SUBSCRIBE_PAGE=pages/alarms/index
WECHAT_SUBSCRIBE_MINIPROGRAM_STATE=formal
WECHAT_SUBSCRIBE_LANG=zh_CN
WECHAT_SUBSCRIBE_FIELD_ALARM_TYPE=thing1
WECHAT_SUBSCRIBE_FIELD_DEVICE_NAME=thing2
WECHAT_SUBSCRIBE_FIELD_TRIGGER_TIME=time3
WECHAT_SUBSCRIBE_FIELD_REMARK=thing4
