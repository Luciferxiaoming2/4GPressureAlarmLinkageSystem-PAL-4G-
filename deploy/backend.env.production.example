APP_NAME=PAL_4G Backend
APP_VERSION=0.1.0
API_V1_PREFIX=/api/v1
DATABASE_URL=sqlite+aiosqlite:///./pal_4g.db
SECRET_KEY=replace-with-a-long-random-production-secret
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ALGORITHM=HS256
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=replace-admin-password

LOG_LEVEL=INFO
ALARM_NOTIFICATION_DISPATCH_INTERVAL_SECONDS=60

MQTT_ENABLED=true
MQTT_BROKER_HOST=mqtt.usr-iot.endpage.net
MQTT_BROKER_PORT=8883
MQTT_USERNAME=replace-mqtt-username
MQTT_PASSWORD=replace-mqtt-password
MQTT_CLIENT_ID=pal_4g_backend
MQTT_TLS_ENABLED=true
MQTT_TLS_CA_CERTS=/etc/ssl/certs/pal4g-mqtt-ca.pem
MQTT_TLS_CERTFILE=
MQTT_TLS_KEYFILE=
MQTT_TLS_INSECURE=false
MQTT_TLS_SERVER_HOSTNAME=mqtt.usr-iot.endpage.net
MQTT_STATUS_TOPIC=pal4g/devices/+/status
MQTT_ALARM_TOPIC=pal4g/devices/+/alarm
MQTT_FEEDBACK_TOPIC=pal4g/devices/+/feedback
MQTT_COMMAND_TOPIC_PREFIX=pal4g/devices

WECHAT_ENABLED=true
WECHAT_LOGIN_USE_REAL_CODE2SESSION=true
WECHAT_APP_ID=replace-wechat-app-id
WECHAT_APP_SECRET=replace-wechat-app-secret
WECHAT_API_BASE_URL=https://api.weixin.qq.com
WECHAT_SUBSCRIBE_TEMPLATE_ID=replace-template-id
WECHAT_SUBSCRIBE_PAGE=pages/alarms/index
WECHAT_SUBSCRIBE_MINIPROGRAM_STATE=formal
WECHAT_SUBSCRIBE_LANG=zh_CN
WECHAT_SUBSCRIBE_FIELD_ALARM_TYPE=thing1
WECHAT_SUBSCRIBE_FIELD_DEVICE_NAME=thing2
WECHAT_SUBSCRIBE_FIELD_TRIGGER_TIME=time3
WECHAT_SUBSCRIBE_FIELD_REMARK=thing4
