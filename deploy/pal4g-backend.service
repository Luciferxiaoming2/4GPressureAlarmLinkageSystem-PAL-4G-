[Unit]
Description=PAL_4G FastAPI Backend
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/pal4g/backend
EnvironmentFile=/opt/pal4g/backend/.env
ExecStart=/opt/pal4g/.venv/bin/python -m uvicorn app.main:app --host 127.0.0.1 --port 8001
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
